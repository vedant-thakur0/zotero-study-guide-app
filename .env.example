# Example environment configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real keys.
#
# API keys are read from the environment as a fallback when they are not set in
# the app config (the Setup tab / app_config.json / llm_config.yaml). Setting
# them here keeps secrets out of any tracked or on-disk config file — the
# recommended posture for a hosted/shared deployment.

# --- Purdue GenAI Studio (default provider) ---
# Get one from genai.rcac.purdue.edu -> avatar -> Settings -> Account -> API Keys
PURDUE_GENAI_API_KEY=

# --- Other providers (only needed if you switch to them) ---
# Anthropic (Claude)
ANTHROPIC_API_KEY=
# OpenAI-compatible hosted endpoints (vLLM / LM Studio run locally need no key)
OPENAI_API_KEY=
